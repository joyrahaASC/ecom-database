{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user.schema.json",
  "title": "User",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^u[0-9]{3,}$",
      "description": "Unique user identifier, e.g. u001"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "passwordHash": {
      "type": "string",
      "minLength": 20,
      "description": "Bcrypt hash, never store plain text passwords"
    },
    "role": {
      "type": "string",
      "enum": ["customer", "admin"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "name", "email", "passwordHash", "role", "createdAt"],
  "additionalProperties": false
}
